#!/bin/bash

export AWS_PAGER=""

PROFILE="ErikTheWizard"
REGION="us-east-2"

echo "🔍 Searching for lab resources (photoapp)..."
aws resource-explorer-2 search \
  --query-string "photoapp" \
  --region $REGION \
  --profile $PROFILE \
  --query "Resources[].{Service:Service, Type:ResourceType, Arn:Arn}" \
  --output table

echo ""
echo "🪣 S3 Buckets:"
aws s3 ls --profile $PROFILE

echo ""
echo "🛢️ RDS Instances:"
aws rds describe-db-instances \
  --region $REGION \
  --profile $PROFILE \
  --query "DBInstances[].DBInstanceIdentifier"

echo ""
echo "🔐 Security Groups:"
aws ec2 describe-security-groups \
  --region $REGION \
  --profile $PROFILE \
  --query "SecurityGroups[].GroupName"
