#!/usr/bin/env bash
# utils/rotate-passwords
# Rotate the photoapp MySQL application-user passwords (photoapp-read-only, photoapp-read-write).
# Generates new passwords, updates RDS via SQL, updates photoapp-config.ini, then validates.
# Does NOT rotate IAM access keys вЂ” use utils/rotate-access-keys for that.
# Runnable from any directory.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CLASS_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
CONFIG="${CLASS_ROOT}/projects/project01/client/photoapp-config.ini"
INFRA_CONFIG="${CLASS_ROOT}/infra/config/photoapp-config.ini"
IMAGE=$(cat "${CLASS_ROOT}/docker/_image-name.txt")
MASTER_PWD_FILE="${CLASS_ROOT}/labs/lab01/Part 01 - AWS Setup/secrets/rds-master-password.txt"

if [[ ! -f "$CONFIG" ]]; then
  echo "[ERROR] $CONFIG not found вЂ” copy from .example first" >&2; exit 1
fi
if [[ ! -f "$INFRA_CONFIG" ]]; then
  echo "[ERROR] $INFRA_CONFIG not found вЂ” copy from .example first" >&2; exit 1
fi
if [[ ! -f "$MASTER_PWD_FILE" ]]; then
  echo "[ERROR] RDS master password file not found: $MASTER_PWD_FILE" >&2; exit 1
fi

ENDPOINT=$(python3 -c "
import configparser
c = configparser.ConfigParser()
c.read('${CONFIG}')
print(c['rds']['endpoint'])
" 2>/dev/null)

if [[ -z "$ENDPOINT" || "$ENDPOINT" == "TODO" ]]; then
  echo "[ERROR] Could not read RDS endpoint from $CONFIG" >&2; exit 1
fi

# Generate new passwords
NEW_RO_PWD=$(python3 -c "import secrets,string; print(secrets.token_urlsafe(16))")
NEW_RW_PWD=$(python3 -c "import secrets,string; print(secrets.token_urlsafe(16))")

printf "\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\n"
printf "в•‘               rotate-passwords                      в•‘\n"
printf "в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n\n"
printf "  Endpoint:  %s\n" "$ENDPOINT"
printf "  Will rotate: photoapp-read-only, photoapp-read-write\n\n"
read -r -p "  Type 'rotate' to confirm: " confirm
if [[ "$confirm" != "rotate" ]]; then
  echo "  Aborted."
  exit 0
fi

MASTER_PWD=$(cat "$MASTER_PWD_FILE")

ROTATE_SQL="
ALTER USER 'photoapp-read-only'@'%' IDENTIFIED BY '${NEW_RO_PWD}';
ALTER USER 'photoapp-read-write'@'%' IDENTIFIED BY '${NEW_RW_PWD}';
FLUSH PRIVILEGES;
"

printf "\n  Rotating passwords in RDS...\n"
docker run --rm -u user -w /home/user \
  -v "${CLASS_ROOT}:/home/user" \
  --network host \
  "$IMAGE" \
  bash -c "mysql -h '${ENDPOINT}' -P 3306 -u admin -p'${MASTER_PWD}' -e \"${ROTATE_SQL}\" 2>&1"

printf "  Updating %s...\n" "$(basename "$CONFIG")"
python3 - "$CONFIG" "$NEW_RO_PWD" "$NEW_RW_PWD" <<'PYEOF'
import sys, configparser
config_path, new_ro, new_rw = sys.argv[1], sys.argv[2], sys.argv[3]
cfg = configparser.ConfigParser(interpolation=None)
cfg.read(config_path)
if 'rds' in cfg:
    cfg['rds']['user_pwd'] = new_rw  # default section uses read-write user
with open(config_path, 'w') as f:
    cfg.write(f)
print(f"  Updated [rds] user_pwd in {config_path}")
PYEOF

printf "  Updating %s...\n" "$(basename "$INFRA_CONFIG")"
python3 - "$INFRA_CONFIG" "$NEW_RO_PWD" <<'PYEOF'
import sys, configparser
config_path, new_ro = sys.argv[1], sys.argv[2]
cfg = configparser.ConfigParser(interpolation=None)
cfg.read(config_path)
if 'rds' in cfg:
    cfg['rds']['user_pwd'] = new_ro  # infra config uses read-only user
with open(config_path, 'w') as f:
    cfg.write(f)
print(f"  Updated [rds] user_pwd in {config_path}")
PYEOF

printf "\n  Running validate-db to confirm connectivity...\n\n"
"${SCRIPT_DIR}/validate-db"
