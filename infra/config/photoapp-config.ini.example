; =====================================================================
; BACKBONE photoapp config
;   Consumed by: utils/validate-db, utils/smoke-test-aws, utils/run-sql
;   MySQL identity: photoapp-read-only (read-only access)
;
; NOTE: TWO files share this filename in the repo. The CLIENT config at
;   projects/project01/client/photoapp-config.ini
; is consumed by the Part 02 Python client (client/photoapp.py) and
; the Part 03 Express server (Part03/server/services/aws.js), uses
; photoapp-read-write, and must also be populated. See
; MetaFiles/QUICKSTART.md step 5.
; =====================================================================

[rds]
endpoint = <full-rds-endpoint from: terraform -chdir=infra/terraform output rds_address>
port_number = 3306
region_name = us-east-2
user_name = photoapp-read-only
user_pwd = <read-only-password>
db_name = photoapp

[s3]
bucket_name = photoapp-<yourname>-mbai460
region_name = us-east-2

[s3readonly]
region_name = us-east-2
aws_access_key_id = <your-access-key-id>
aws_secret_access_key = <your-secret-access-key>

[s3readwrite]
region_name = us-east-2
aws_access_key_id = <your-access-key-id>
aws_secret_access_key = <your-secret-access-key>
