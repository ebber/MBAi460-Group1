# ============================================================
# Credential and secret files — NEVER commit these
# ============================================================

# Agent secrets directory (aws-credentials, aws-config, access key CSVs)
secrets/aws-credentials
secrets/aws-config
secrets/*.csv
secrets/*.enc

# Lab01 RDS master password
labs/lab01/Part 01 - AWS Setup/secrets/rds-master-password.txt
labs/lab01/Part 01 - AWS Setup/secrets/rds-master-password.txt.enc

# Lab02 shorten app config (contains DB credentials)
labs/lab02/shorten-config.ini

# Gradescope auth token — sensitive credential, never commit
.gradescope

# Backbone + client configs — contain live RDS endpoints and credentials
# Commit the .example templates; populate live files locally
infra/config/photoapp-config.ini
projects/project01/client/photoapp-config.ini

# ============================================================
# Terraform — also handled by infra/terraform/.gitignore
# Repeated here as belt-and-suspenders: protects against broad
# `git add .` from repo root before nested .gitignore takes effect
# ============================================================
infra/terraform/*.tfvars
infra/terraform/*.tfvars.json
infra/terraform/*.tfstate
infra/terraform/*.tfstate.backup
infra/terraform/.terraform/

# ============================================================
# Terraform plan output files — run `terraform apply planfile` then delete
# ============================================================
infra/terraform/*.tfplan

# ============================================================
# Generic secrets / key files — belt-and-suspenders
# ============================================================
.env
*.key
*.pem

# ============================================================
# Agent working plans — internal coordination artifacts, not project history
# ============================================================
MetaFiles/plans/

# ============================================================
# Node / npm ignores — applies to any node_modules/ at any depth
# (Project 01 Part 03 has its own; future labs/projects may add more)
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================
# Submission tarball outputs (Phase 0.4 § 4.3 packaging script)
# Note: NOT a blanket **/dist because frontend/dist is checked-in
# pre-built SPA assets that the server serves at runtime.
# ============================================================
projects/project01/Part03/dist/

# ============================================================
# Standard ignores
# ============================================================
**/.DS_Store
**/__pycache__/
**/*.pyc
# Editor backup files (vim *~, emacs #file#, etc.)
**/*~
# Generated log files — keep on disk for incident response, don't commit
log.txt
