; =====================================================================
; CLIENT photoapp config
;   Consumed by: projects/project01/client/photoapp.py (Part 02 Python client)
;                projects/project01/Part03/server/services/aws.js (Part 03 Express server)
;   MySQL identity: photoapp-read-write (read-write access)
;
; NOTE: TWO files share this filename in the repo. The BACKBONE config at
;   infra/config/photoapp-config.ini
; is consumed by utils/validate-db, utils/smoke-test-aws, utils/run-sql,
; uses photoapp-read-only, and must also be populated. See
; MetaFiles/QUICKSTART.md step 5.
; =====================================================================

[rds]
endpoint = <full-rds-endpoint from: terraform -chdir=infra/terraform output rds_address>
port_number = 3306
region_name = us-east-2
user_name = photoapp-read-write
user_pwd = <read-write-password>
db_name = photoapp

[s3]
bucket_name = photoapp-<yourname>-mbai460
region_name = us-east-2

[s3readonly]
region_name = us-east-2
aws_access_key_id = <your-access-key-id>
aws_secret_access_key = <your-secret-access-key>

[s3readwrite]
region_name = us-east-2
aws_access_key_id = <your-access-key-id>
aws_secret_access_key = <your-secret-access-key>
